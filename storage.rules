rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    allow read: if true;

    match /lesson_videos/{fileName} {
      allow write: if request.auth != null;
      allow delete: if request.auth != null && isAdmin();
    }

    match /{allPaths=**} {
      allow write: if request.auth != null;
    }

    function isAdmin() {
      return firestore.exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
